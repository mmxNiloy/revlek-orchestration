# Application
PORT=5000
NODE_ENV=development

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/revlek_website_backend
PG_POOL_MAX=10
PG_IDLE_TIMEOUT=10000
PG_CONNECTION_TIMEOUT=30000

# Nodemailer
NODEMAILER_USER=
NODEMAILER_PASS=
NODEMAILER_HOST=
NODEMAILER_USER_FROM=
ADMIN_EMAIL=
NODEMAILER_SECURE=false
NODEMAILER_POOL=true
NODEMAILER_MAX_CONNECTIONS=10
NODEMAILER_MAX_MESSAGES=100

# Swagger
SWAGGER_TITLE="REVLEK - Building Tomorrow's Technology"
SWAGGER_DESCRIPTION="Transform your business with cutting-edge software solutions, AI innovation, and modern technology. Trusted by 150+ companies worldwide."
SWAGGER_VERSION="1.0"

# JWT
JWT_ACCESS_TOKEN_COOKIE_NAME=revlek_access
JWT_SECRET=your-secret
JWT_EXPIRATION_TIME_MS=3600000 # 1h
JWT_REFRESH_TOKEN_EXPIRATION_TIME_MS=604800000 # 7d
JWT_REFRESH_TOKEN_SECRET=your-secret
JWT_REFRESH_TOKEN_COOKIE_NAME=revlek_refresh

# Cookies
COOKIE_SECRETS=secret1,secret2,secret3

# Auth
BCRYPT_SALT_ROUNDS=12
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MS=900000

# Redis
REDIS_NAMESPACE=revlek
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_USERNAME=
REDIS_PASSWORD=
REDIS_DATABASE=0
CACHE_TTL_SECONDS=300

# BullMQ
BULLMQ_DATABASE=1
BULLMQ_PREFIX=revlek

# Uploads
UPLOAD_DIR=uploads
JOB_RESUME_MAX_MB=5
JOB_SUPPORTING_MAX_MB=10
JOB_SUPPORTING_MAX_COUNT=5
JOB_RESUME_MIME_TYPES=application/pdf,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document
JOB_SUPPORTING_MIME_TYPES=application/pdf,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document,image/jpeg,image/png,image/gif,image/webp
JOB_APPLY_THROTTLE_TTL_MS = 3600000
JOB_APPLY_THROTTLE_LIMIT=5
  
# Cloudflare Turnstile
# These are example keys, change them in prod
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA
TURNSTILE_SITE_KEY=1x00000000000000000000AA

# Admin panel base URL for email links
ADMIN_PANEL_URL=

# Email Resources
EMAIL_LOGO_URL=
SITE_URL=